# TheBhagya — Environment Variables
# Copy this to .env and fill in your values
# Never commit .env to version control

# ── Database ──────────────────────────────────────────────────────────────
# SQLite (local dev — zero setup, works out of the box)
DATABASE_URL=sqlite+aiosqlite:///./data/bhagyaai.db

# PostgreSQL (production)
# DATABASE_URL=postgresql+asyncpg://bhagya:bhagya123@localhost:5432/bhagyaai

# ── Anthropic / Claude AI (Phase 3 — Destiny Chat) ───────────────────────
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Model to use for Destiny Chat (claude-haiku is fast + cheap)
CHAT_MODEL=claude-haiku-4-5-20251001
CHAT_MAX_TOKENS=1024

# ── Razorpay Billing (Phase 4) ────────────────────────────────────────────
# Get from: https://dashboard.razorpay.com → Settings → API Keys
RAZORPAY_KEY_ID=rzp_test_your-key-id-here
RAZORPAY_KEY_SECRET=your-razorpay-secret-here

# ── Ephemeris ────────────────────────────────────────────────────────────
# Leave empty to use built-in Moshier ephemeris (accurate 1800–2100)
# Set to path of Swiss Ephemeris .se1 files for extended date range
EPHE_PATH=

# ── Super Admin ──────────────────────────────────────────────────────────
# Login at /admin — these credentials are NEVER stored in the DB
ADMIN_EMAIL=admin@thebhagya.com
ADMIN_PASSWORD=TheBhagya@Admin2025!

# ── App ──────────────────────────────────────────────────────────────────
APP_ENV=development          # development | production
SECRET_KEY=change-me-in-production-use-long-random-string
API_V1_PREFIX=/v1

# CORS — comma-separated origins allowed to call the API
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8000,http://localhost:19006

# ── Future ───────────────────────────────────────────────────────────────
# REDIS_URL=redis://localhost:6379/0     (for rate limiting / caching)
# PINECONE_API_KEY=                       (for RAG over classical texts)
# PINECONE_INDEX=thebhagya-rag
# AWS_ACCESS_KEY_ID=                      (for production S3 / ECS)
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=ap-south-1
